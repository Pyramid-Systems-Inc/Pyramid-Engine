{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022-debug",
      "displayName": "VS2022 Debug",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "PYRAMID_BUILD_EXAMPLES": "ON",
        "PYRAMID_BUILD_TESTS": "OFF",
        "PYRAMID_BUILD_TOOLS": "OFF"
      }
    },
    {
      "name": "vs2022-debug-tests",
      "displayName": "VS2022 Debug + Tests",
      "inherits": "vs2022-debug",
      "cacheVariables": {
        "PYRAMID_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
      "configurePreset": "vs2022-debug",
      "configuration": "Debug"
    },
    {
      "name": "build-debug-clean",
      "configurePreset": "vs2022-debug",
      "configuration": "Debug",
      "cleanFirst": true
    },
    {
      "name": "build-debug-tests-clean",
      "configurePreset": "vs2022-debug-tests",
      "configuration": "Debug",
      "cleanFirst": true
    }
  ],
  "testPresets": [
    {
      "name": "test-debug",
      "configurePreset": "vs2022-debug-tests",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}

